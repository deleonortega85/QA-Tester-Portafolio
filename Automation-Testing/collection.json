{
  "info": {
    "name": "Biblioteca API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Booking",
      "request": {
        "method": "POST",
        "url": "https://restful-booker.herokuapp.com/booking",
        "body": {
          "mode": "raw",
          "raw": "{\n    \"firstname\": \"John\",\n    \"lastname\": \"Doe\",\n    \"totalprice\": 150,\n    \"depositpaid\": true,\n    \"bookingdates\": {\n        \"checkin\": \"2024-01-01\",\n        \"checkout\": \"2024-01-10\"\n    },\n    \"additionalneeds\": \"Breakfast\"\n}"
        }
      }
    },
    {
      "name": "Get booking",
      "request": {
        "method": "GET",
        "url": "https://restful-booker.herokuapp.com/booking/{{bookingId}}"
      }
    },
    {
      "name": "Update booking",
      "request": {
        "method": "PUT",
        "url": "https://restful-booker.herokuapp.com/booking/{{bookingId}}"
      }
    },
    {
      "name": "Delete booking",
      "request": {
        "method": "DELETE",
        "url": "https://restful-booker.herokuapp.com/booking/{{bookingId}}"
      }
    }
  ]
}